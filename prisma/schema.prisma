generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model User {
  id                      String                   @id @default(uuid())
  supabaseId              String                   @unique @map("supabase_id")
  email                   String?
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  phone                   String?                  @unique(map: "users_phone_unique_not_null", where: raw("(phone IS NOT NULL)"))
  avatarUrl               String?                  @map("avatar_url")
  role                    String                   @default("user")
  isActive                Boolean                  @default(true) @map("is_active")
  emailVerified           Boolean                  @default(false) @map("email_verified")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at")
  bio                     String?
  settings                Json?
  bookmarks               Bookmark[]
  questionFlags           QuestionFlag[]
  calendarSyncSetting     CalendarSyncSetting?
  chatConversations       ChatConversation[]
  contactSubmissions      ContactSubmission[]
  editorialBookmarks      EditorialBookmark[]
  editorialProgress       EditorialProgress[]
  feedbacks               Feedback[]
  forumAnswers            ForumAnswer[]
  forumBookmarks          ForumBookmark[]
  forumPosts              ForumPost[]
  forumVotes              ForumVote[]
  groupMessages           GroupMessage[]
  journalEntries          JournalEntry[]
  mainsAttempts           MainsAttempt[]
  mcqAttempts             MCQAttempt[]
  mentorBookings          MentorBooking[]
  mentorQuestions         MentorQuestion[]
  mindToolSessions        MindToolSession[]
  mockTestAttempts        MockTestAttempt[]
  mockTestMainsAttempts   MockTestMainsAttempt[]
  mockTestMaterialUploads MockTestMaterialUpload[]
  moodCheckIns            MoodCheckIn[]
  notifications           Notification[]
  orders                  Order[]
  payments                Payment[]
  pyqMainsAttempts        PyqMainsAttempt[]
  pyqPrelimsAttempts      PyqPrelimsAttempt[]
  pyqUploads              PYQUpload[]
  groupMemberships        StudyGroupMember[]
  createdGroups           StudyGroup[]             @relation("CreatedGroups")
  studyMaterialUploads    StudyMaterialUpload[]
  studyPlanTasks          StudyPlanTask[]
  studyStreak             StudyStreak?
  subscriptions           Subscription[]
  couponRedemptions       SubscriptionCouponRedemption[]
  supportTickets          SupportTicket[]
  syllabusCoverage        SyllabusCoverage[]
  syllabusTrackerState    SyllabusTrackerState?
  testSeriesAttempts      TestSeriesAttempt[]
  activities              UserActivity[]
  usageEvents             UsageEvent[]
  entitlementOverrides    UserEntitlementOverride[]
  seenMcqQuestions        UserSeenMCQ[]
  seriesEnrollments       UserSeriesEnrollment[]
  streak                  UserStreak?
  weeklyGoals             WeeklyGoal[]
  wellnessStreak          WellnessStreak?

  @@map("users")
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date")
  weekActivity   Json?     @map("week_activity")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

model DailyMCQ {
  id            String        @id @default(uuid())
  date          DateTime      @unique @db.Date
  title         String
  topic         String
  tags          String[]
  questionCount Int           @map("question_count")
  timeLimit     Int           @map("time_limit")
  totalMarks    Int           @map("total_marks")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  attempts      MCQAttempt[]
  questions     MCQQuestion[]

  @@map("daily_mcqs")
}

model MCQQuestion {
  id            String        @id @default(uuid())
  dailyMcqId    String        @map("daily_mcq_id")
  sourceQuestionBankId String? @map("source_question_bank_id")
  questionNum   Int           @map("question_num")
  questionText  String        @map("question_text")
  category      String
  difficulty    String
  options       Json
  correctOption String        @map("correct_option")
  explanation   String?
  createdAt     DateTime      @default(now()) @map("created_at")
  dailyMcq      DailyMCQ      @relation(fields: [dailyMcqId], references: [id], onDelete: Cascade)
  responses     MCQResponse[]

  @@unique([dailyMcqId, questionNum])
  @@index([sourceQuestionBankId])
  @@map("mcq_questions")
}

model MCQAttempt {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  dailyMcqId   String        @map("daily_mcq_id")
  score        Int           @default(0)
  totalMarks   Int           @map("total_marks")
  correctCount Int           @default(0) @map("correct_count")
  wrongCount   Int           @default(0) @map("wrong_count")
  skippedCount Int           @default(0) @map("skipped_count")
  accuracy     Float         @default(0)
  timeTaken    Int           @default(0) @map("time_taken")
  rank         Int?
  percentile   Float?
  strongTopics String[]      @map("strong_topics")
  weakTopics   String[]      @map("weak_topics")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  dailyMcq     DailyMCQ      @relation(fields: [dailyMcqId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses    MCQResponse[]

  @@unique([userId, dailyMcqId])
  @@map("mcq_attempts")
}

model MCQResponse {
  id             String      @id @default(uuid())
  attemptId      String      @map("attempt_id")
  questionId     String      @map("question_id")
  selectedOption String?     @map("selected_option")
  isCorrect      Boolean?    @map("is_correct")
  timeTaken      Int         @default(0) @map("time_taken")
  attempt        MCQAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       MCQQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("mcq_responses")
}

model DailyMainsQuestion {
  id           String         @id @default(uuid())
  date         DateTime       @unique @db.Date
  title        String
  questionText String         @map("question_text")
  paper        String
  subject      String
  marks        Int
  wordLimit    Int            @map("word_limit")
  timeLimit    Int            @map("time_limit")
  instructions String?
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  attempts     MainsAttempt[]

  @@map("daily_mains_questions")
}

model MainsAttempt {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  questionId  String             @map("question_id")
  answerText  String?            @map("answer_text")
  fileUrl     String?            @map("file_url")
  wordCount   Int                @default(0) @map("word_count")
  submittedAt DateTime?          @map("submitted_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  question    DailyMainsQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation  MainsEvaluation?

  @@unique([userId, questionId])
  @@map("mains_attempts")
}

model MainsEvaluation {
  id                String       @id @default(uuid())
  attemptId         String       @unique @map("attempt_id")
  score             Float
  maxScore          Float        @map("max_score")
  status            String       @default("pending")
  strengths         String[]
  improvements      String[]
  suggestions       String[]
  detailedFeedback  String?      @map("detailed_feedback")
  evaluatedAt       DateTime?    @map("evaluated_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  metrics           Json?
  demandCoverage    Json?        @map("demand_coverage")
  sectionFeedback   Json?        @map("section_feedback")
  modelAnswer       String?      @map("model_answer")
  annotationPlan    Json?        @map("annotation_plan")
  checkedCopyUrl    String?      @map("checked_copy_url")
  checkedCopyStatus String?      @map("checked_copy_status")
  evaluationMode    String?      @map("evaluation_mode")
  ragDiagnostics    Json?        @map("rag_diagnostics")
  checkedCopyPages  Json?        @map("checked_copy_pages")
  keyTerms             Json?        @map("key_terms")
  nextAttemptFocus     String?      @map("next_attempt_focus")
  evaluatorConclusion  String?      @map("evaluator_conclusion")
  modelAnswerKeyPoints Json?        @map("model_answer_key_points")
  modelAnswerContent   String?      @map("model_answer_content")
  parameterScores      Json?        @map("parameter_scores")
  attempt           MainsAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("mains_evaluations")
}

model Editorial {
  id          String              @id @default(uuid())
  title       String
  source      String
  sourceUrl   String?             @map("source_url")
  category    String
  summary     String?
  content     String?
  aiSummary   String?             @map("ai_summary")
  tags        String[]
  publishedAt DateTime            @map("published_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  bookmarks   EditorialBookmark[]
  progress    EditorialProgress[]

  @@index([publishedAt])
  @@map("editorials")
}

model EditorialProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  editorialId String    @map("editorial_id")
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  editorial   Editorial @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, editorialId])
  @@map("editorial_progress")
}

model EditorialBookmark {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  editorialId String    @map("editorial_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  editorial   Editorial @relation(fields: [editorialId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, editorialId])
  @@map("editorial_bookmarks")
}

model MockTest {
  id            String                 @id @default(uuid())
  title         String
  source        String
  examMode      String                 @map("exam_mode")
  paperType     String?                @map("paper_type")
  subject       String?
  difficulty    String
  questionCount Int                    @map("question_count")
  duration      Int
  totalMarks    Int                    @map("total_marks")
  isGenerated   Boolean                @default(false) @map("is_generated")
  createdAt     DateTime               @default(now()) @map("created_at")
  attempts      MockTestAttempt[]
  mainsAttempts MockTestMainsAttempt[]
  questions     MockTestQuestion[]

  @@map("mock_tests")
}

model MockTestQuestion {
  id            String                 @id @default(uuid())
  mockTestId    String                 @map("mock_test_id")
  sourceQuestionBankId String?         @map("source_question_bank_id")
  questionNum   Int                    @map("question_num")
  questionText  String                 @map("question_text")
  subject       String
  category      String
  difficulty    String
  options       Json
  correctOption String                 @map("correct_option")
  explanation   String?
  createdAt     DateTime               @default(now()) @map("created_at")
  mainsAttempts MockTestMainsAttempt[]
  mockTest      MockTest               @relation(fields: [mockTestId], references: [id], onDelete: Cascade)

  @@unique([mockTestId, questionNum])
  @@index([sourceQuestionBankId])
  @@map("mock_test_questions")
}

model MockTestAttempt {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  mockTestId   String    @map("mock_test_id")
  answers      Json?
  score        Int       @default(0)
  totalMarks   Int       @map("total_marks")
  correctCount Int       @default(0) @map("correct_count")
  wrongCount   Int       @default(0) @map("wrong_count")
  skippedCount Int       @default(0) @map("skipped_count")
  accuracy     Float     @default(0)
  timeTaken    Int       @default(0) @map("time_taken")
  subjectWise  Json?     @map("subject_wise")
  analysis     String?
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  mockTest     MockTest  @relation(fields: [mockTestId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mock_test_attempts")
}

model TestSeries {
  id               String                 @id @default(uuid())
  title            String
  description      String
  examMode         String                 @map("exam_mode")
  subject          String?
  difficulty       String
  questionsPerTest Int                    @map("questions_per_test")
  createdAt        DateTime               @default(now()) @map("created_at")
  isActive         Boolean                @default(true) @map("is_active")
  price            Int                    @default(0)
  totalTests       Int                    @default(0) @map("total_tests")
  tests            TestSeriesTest[]
  enrollments      UserSeriesEnrollment[]

  @@map("test_series")
}

model UserSeriesEnrollment {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  seriesId       String     @map("series_id")
  testsCompleted Int        @default(0) @map("tests_completed")
  enrolledAt     DateTime   @default(now()) @map("enrolled_at")
  series         TestSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@map("user_series_enrollments")
}

model TestSeriesTest {
  id            String               @id @default(uuid())
  seriesId      String               @map("series_id")
  title         String
  createdAt     DateTime             @default(now()) @map("created_at")
  description   String?
  duration      Int                  @default(120)
  examMode      String               @default("prelims") @map("exam_mode")
  isPublished   Boolean              @default(false) @map("is_published")
  questionCount Int                  @default(0) @map("question_count")
  subject       String?
  testNumber    Int                  @default(1) @map("test_number")
  totalMarks    Int                  @default(0) @map("total_marks")
  attempts      TestSeriesAttempt[]
  questions     TestSeriesQuestion[]
  series        TestSeries           @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, testNumber])
  @@index([seriesId])
  @@map("test_series_tests")
}

model TestSeriesQuestion {
  id            String         @id @default(uuid())
  testId        String         @map("test_id")
  options       Json
  explanation   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  category      String         @default("")
  correctOption String         @default("A") @map("correct_option")
  difficulty    String         @default("medium")
  questionNum   Int            @default(0) @map("question_num")
  questionText  String         @default("") @map("question_text")
  subject       String         @default("")
  test          TestSeriesTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, questionNum])
  @@index([testId])
  @@map("test_series_questions")
}

model TestSeriesAttempt {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  testId       String         @map("test_id")
  answers      Json?
  score        Int            @default(0)
  accuracy     Float          @default(0)
  completedAt  DateTime?      @map("completed_at")
  correctCount Int            @default(0) @map("correct_count")
  createdAt    DateTime       @default(now()) @map("created_at")
  skippedCount Int            @default(0) @map("skipped_count")
  subjectWise  Json?          @map("subject_wise")
  timeTaken    Int            @default(0) @map("time_taken")
  totalMarks   Int            @default(0) @map("total_marks")
  wrongCount   Int            @default(0) @map("wrong_count")
  test         TestSeriesTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, testId])
  @@index([userId])
  @@index([testId])
  @@map("test_series_attempts")
}

model StudyPlanTask {
  id                      String    @id @default(uuid())
  userId                  String    @map("user_id")
  title                   String
  description             String?
  subject                 String?
  type                    String    @default("study")
  date                    DateTime  @db.Date
  startTime               String?   @map("start_time")
  endTime                 String?   @map("end_time")
  duration                Int?
  actualDuration          Int?      @map("actual_duration")
  isCompleted             Boolean   @default(false) @map("is_completed")
  completedAt             DateTime? @map("completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  googleCalendarEventId   String?   @map("google_calendar_event_id")
  googleCalendarSyncedAt  DateTime? @map("google_calendar_synced_at")
  googleCalendarSyncError String?   @map("google_calendar_sync_error")
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("study_plan_tasks")
}

model CalendarSyncSetting {
  id                          String    @id @default(uuid())
  userId                      String    @unique @map("user_id")
  provider                    String    @default("google")
  enabled                     Boolean   @default(false)
  enabledAt                   DateTime? @map("enabled_at")
  googleAccessTokenEncrypted  String?   @map("google_access_token_encrypted")
  googleRefreshTokenEncrypted String?   @map("google_refresh_token_encrypted")
  googleTokenExpiresAt        DateTime? @map("google_token_expires_at")
  googleScope                 String?   @map("google_scope")
  googleCalendarId            String    @default("primary") @map("google_calendar_id")
  timezone                    String    @default("Asia/Kolkata")
  lastSyncError               String?   @map("last_sync_error")
  connectedAt                 DateTime? @map("connected_at")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, enabled])
  @@map("calendar_sync_settings")
}

model StudyStreak {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  currentStreak  Int       @default(0) @map("current_streak")
  longestStreak  Int       @default(0) @map("longest_streak")
  totalStudyDays Int       @default(0) @map("total_study_days")
  lastStudyDate  DateTime? @map("last_study_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_streaks")
}

model WeeklyGoal {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  title        String
  targetCount  Int      @map("target_count")
  currentCount Int      @default(0) @map("current_count")
  weekStart    DateTime @map("week_start") @db.Date
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
  @@map("weekly_goals")
}

model SyllabusCoverage {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  subject       String
  coveredTopics Int      @default(0) @map("covered_topics")
  totalTopics   Int      @map("total_topics")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
  @@map("syllabus_coverage")
}

model VideoSubject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  iconUrl     String?  @map("icon_url")
  videoCount  Int      @default(0) @map("video_count")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  videos      Video[]

  @@map("video_subjects")
}

model Video {
  id           String          @id @default(uuid())
  subjectId    String          @map("subject_id")
  title        String
  description  String?
  videoUrl     String?         @map("video_url")
  thumbnailUrl String?         @map("thumbnail_url")
  duration     Int?
  instructor   String?
  order        Int             @default(0)
  isPublished  Boolean         @default(true) @map("is_published")
  createdAt    DateTime        @default(now()) @map("created_at")
  questions    VideoQuestion[]
  subject      VideoSubject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("videos")
}

model VideoQuestion {
  id            String   @id @default(uuid())
  videoId       String   @map("video_id")
  question      String
  options       Json
  correctOption Int      @map("correct_option")
  explanation   String?
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_questions")
}

model MentorQuestion {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  question  String
  answer    String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mentor_questions")
}

model Subject {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  iconUrl     String?   @map("icon_url")
  tags        String[]
  order       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  chapters    Chapter[]

  @@map("subjects")
}

model Chapter {
  id          String          @id @default(uuid())
  subjectId   String          @map("subject_id")
  title       String
  description String?
  order       Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")
  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  materials   StudyMaterial[]

  @@map("chapters")
}

model StudyMaterial {
  id                 String            @id @default(uuid())
  chapterId          String?           @map("chapter_id")
  title              String
  type               String            @default("Notes")
  fileUrl            String?           @map("file_url")
  fileSize           Int?              @map("file_size")
  pageCount          Int?              @map("page_count")
  createdAt          DateTime          @default(now()) @map("created_at")
  syllabusSubTopicId String?           @map("syllabus_sub_topic_id")
  description        String?
  accessLevel        String            @default("free") @map("access_level")
  isPublished        Boolean           @default(true) @map("is_published")
  order              Int               @default(0)
  chapter            Chapter?          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  syllabusSubTopic   SyllabusSubTopic? @relation(fields: [syllabusSubTopicId], references: [id])

  @@index([syllabusSubTopicId])
  @@map("study_materials")
}

model PricingPlan {
  id            String         @id @default(uuid())
  name          String
  price         Int
  duration      String
  features      String[]
  isPopular     Boolean        @default(false) @map("is_popular")
  order         Int            @default(0)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  durationDays  Int            @default(90) @map("duration_days")
  tier          String         @default("rise")
  billingCycle  String         @default("quarterly") @map("billing_cycle")
  originalPrice Int?           @map("original_price")
  entitlements  Json?
  razorpayPlanId String?       @map("razorpay_plan_id")
  razorpayPlanVerifiedAt DateTime? @map("razorpay_plan_verified_at")
  orders        Order[]
  subscriptions Subscription[]

