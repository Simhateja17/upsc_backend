  evaluationMode    String?              @map("evaluation_mode")
  ragDiagnostics    Json?                @map("rag_diagnostics")
  checkedCopyPages  Json?                @map("checked_copy_pages")
  keyTerms             Json?                @map("key_terms")
  nextAttemptFocus     String?              @map("next_attempt_focus")
  evaluatorConclusion  String?              @map("evaluator_conclusion")
  modelAnswerKeyPoints Json?                @map("model_answer_key_points")
  modelAnswerContent   String?              @map("model_answer_content")
  parameterScores      Json?                @map("parameter_scores")
  attempt           MockTestMainsAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("mock_test_mains_evaluations")
}

model Faq {
  id        String   @id @default(uuid())
  category  String
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model StudyGroup {
  id          String             @id @default(uuid())
  name        String
  description String?
  subject     String
  status      String             @default("open")
  maxMembers  Int                @default(50) @map("max_members")
  createdById String             @map("created_by_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  messages    GroupMessage[]
  members     StudyGroupMember[]
  creator     User               @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([subject])
  @@index([status])
  @@map("study_groups")
}

model StudyGroupMember {
  id       String     @id @default(uuid())
  groupId  String     @map("group_id")
  userId   String     @map("user_id")
  joinedAt DateTime   @default(now()) @map("joined_at")
  isActive Boolean    @default(true) @map("is_active")
  group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("study_group_members")
}

model GroupMessage {
  id        String     @id @default(uuid())
  groupId   String     @map("group_id")
  userId    String     @map("user_id")
  content   String
  createdAt DateTime   @default(now()) @map("created_at")
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("group_messages")
}

model Order {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  amount    Int
  status    String      @default("pending")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  planId    String      @map("plan_id")
  plan      PricingPlan @relation(fields: [planId], references: [id])
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([userId, status])
  @@map("orders")
}

model Payment {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  orderId           String?       @map("order_id")
  subscriptionId    String?       @map("subscription_id")
  amount            Int
  currency          String        @default("INR")
  status            String
  provider          String
  providerPaymentId String?       @map("provider_payment_id")
  receiptUrl        String?       @map("receipt_url")
  paidAt            DateTime?     @map("paid_at")
  failedAt          DateTime?     @map("failed_at")
  failureReason     String?       @map("failure_reason")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  providerOrderId   String?       @map("provider_order_id")
  metadata          Json?
  couponRedemptions SubscriptionCouponRedemption[]
  order             Order?        @relation(fields: [orderId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("payments")
}

model Subscription {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  planId      String      @map("plan_id")
  status      String
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  autoRenew   Boolean     @default(true) @map("auto_renew")
  cancelledAt DateTime?   @map("cancelled_at")
  razorpaySubscriptionId String? @unique @map("razorpay_subscription_id")
  razorpayPlanId String? @map("razorpay_plan_id")
  razorpayStatus String? @map("razorpay_status")
  currentStart DateTime? @map("current_start")
  currentEnd DateTime? @map("current_end")
  chargeAt DateTime? @map("charge_at")
  graceEndsAt DateTime? @map("grace_ends_at")
  supersededAt DateTime? @map("superseded_at")
  supersededBySubscriptionId String? @map("superseded_by_subscription_id")
  pausedAt DateTime? @map("paused_at")
  resumedAt DateTime? @map("resumed_at")
  failureReason String? @map("failure_reason")
  metadata Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  payments    Payment[]
  couponRedemptions SubscriptionCouponRedemption[]
  plan        PricingPlan @relation(fields: [planId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([razorpaySubscriptionId])
  @@index([razorpayStatus])
  @@map("subscriptions")
}

model RazorpayWebhookEvent {
  id               String    @id @default(uuid())
  eventId          String    @unique @map("event_id")
  eventType        String    @map("event_type")
  entity           String?
  entityId         String?   @map("entity_id")
  payload          Json
  processingStatus String    @default("pending") @map("processing_status")
  processedAt      DateTime? @map("processed_at")
  error            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([eventType, createdAt])
  @@index([processingStatus, createdAt])
  @@map("razorpay_webhook_events")
}

model SubscriptionCoupon {
  id                    String   @id @default(uuid())
  code                  String   @unique
  razorpayOfferId       String   @map("razorpay_offer_id")
  discountLabel         String?  @map("discount_label")
  maxRedemptions        Int?     @map("max_redemptions")
  maxRedemptionsPerUser Int?     @map("max_redemptions_per_user")
  redeemedCount         Int      @default(0) @map("redeemed_count")
  validFrom             DateTime? @map("valid_from")
  validUntil            DateTime? @map("valid_until")
  allowedTiers          String[] @default([]) @map("allowed_tiers")
  allowedBillingCycles  String[] @default([]) @map("allowed_billing_cycles")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  redemptions           SubscriptionCouponRedemption[]

  @@index([code, isActive])
  @@map("subscription_coupons")
}

model SubscriptionCouponRedemption {
  id             String   @id @default(uuid())
  couponId       String   @map("coupon_id")
  userId         String   @map("user_id")
  subscriptionId String   @map("subscription_id")
  paymentId      String?  @map("payment_id")
  status         String   @default("pending")
  redeemedAt     DateTime? @map("redeemed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  coupon         SubscriptionCoupon @relation(fields: [couponId], references: [id])
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payment        Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([subscriptionId, status])
  @@unique([couponId, subscriptionId])
  @@map("subscription_coupon_redemptions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  type      String   @default("general")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model ForumPost {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  title     String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  body      String
  status    String          @default("open")
  subject   String
  tags      String[]
  views     Int             @default(0)
  votes     Int             @default(0)
  answers   ForumAnswer[]
  bookmarks ForumBookmark[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  votesRel  ForumVote[]

  @@index([subject, createdAt])
  @@index([status, createdAt])
  @@map("forum_posts")
}

model ForumAnswer {
  id         String      @id @default(uuid())
  postId     String      @map("post_id")
  userId     String      @map("user_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  body       String
  isAccepted Boolean     @default(false) @map("is_accepted")
  votes      Int         @default(0)
  post       ForumPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votesRel   ForumVote[]

  @@index([postId, createdAt])
  @@map("forum_answers")
}

model ForumVote {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  postId    String?      @map("post_id")
  answerId  String?      @map("answer_id")
  createdAt DateTime     @default(now()) @map("created_at")
  direction Int
  updatedAt DateTime     @updatedAt @map("updated_at")
  answer    ForumAnswer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  post      ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, answerId])
  @@map("forum_votes")
}

model ForumBookmark {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  postId    String    @map("post_id")
  createdAt DateTime  @default(now()) @map("created_at")
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("forum_bookmarks")
}

model MoodCheckIn {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  mood      String
  energy    Int      @default(5)
  note      String?
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("mood_check_ins")
}

model WellnessStreak {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastCheckIn   DateTime? @map("last_check_in")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wellness_streaks")
}

model MindToolSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  toolType  String   @map("tool_type")
  duration  Int
  completed Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mind_tool_sessions")
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @default("Free write")
  text      String
  moodEmoji String?  @map("mood_emoji")
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("journal_entries")
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  title      String
  source     String
  sourceUrl  String?  @map("source_url")
  tag        String?
  tagColor   String?  @map("tag_color")
  content    Json?
  isPinned   Boolean  @default(false) @map("is_pinned")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entityType])
  @@index([userId, createdAt])
  @@map("bookmarks")
}

model QuestionFlag {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  questionType String   @map("question_type")
  questionId   String   @map("question_id")
  questionText String   @map("question_text")
  reason       String?
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionType, questionId])
  @@index([status])
  @@map("question_flags")
}

model SupportTicket {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  subject     String
  description String
  category    String    @default("general")
  status      String    @default("open")
  priority    String    @default("medium")
  adminNotes  String?   @map("admin_notes")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("support_tickets")
}
