
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...   # Your anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Your service role key (keep secret!)
PHONE_AUTH_ENABLED=false
TWOFACTOR_API_KEY=your-2factor-api-key
TWOFACTOR_OTP_TEMPLATE_NAME=OTP
SEND_SMS_HOOK_SECRETS=v1,whsec_your-supabase-auth-hook-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google-calendar/callback
GOOGLE_CALENDAR_STATE_SECRET=replace-with-a-long-random-string
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-string
USD_TO_INR=90                         # USD -> INR exchange rate for cost tracking
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small   # Your embedding deployment name
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini                  # Your chat deployment name
AZURE_OPENAI_OCR_DEPLOYMENT=gpt-5.4-mini                   # Vision transcription deployment for handwritten uploads
AZURE_OPENAI_OCR_MAX_PAGES=6                               # Max PDF pages to transcribe per answer upload
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-read
GOOGLE_VISION_API_KEY=your-google-vision-api-key           # Google Cloud Vision API key (optional if Azure OCR is configured)
GEMINI_API_KEY=your-gemini-api-key                         # Google Gemini API key (for checked-copy generation)
RESEND_API_KEY=re_...              # Your Resend API key
RESEND_FROM_EMAIL=noreply@yourdomain.com  # Must be verified domain in Resend
NEWS_API_KEY=your_news_api_key_here  # Your News API key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
